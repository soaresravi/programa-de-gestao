quarkus.datasource.db-kind=mysql
quarkus.datasource.username=root
quarkus.datasource.password=
quarkus.datasource.jdbc.url=jdbc:mysql://localhost:3306/gestao_colchoes?useSSL=false&serverTimezone=UTC

# Hibernate
quarkus.hibernate-orm.database.generation=update
quarkus.hibernate-orm.log.sql=true
quarkus.hibernate-orm.log.bind-parameters=true
quarkus.hibernate-orm.database.version-check.enabled=false

# Email (configure suas credenciais)
quarkus.mailer.host=smtp.gmail.com
quarkus.mailer.port=587
quarkus.mailer.start-tls=REQUIRED
quarkus.mailer.username=SEU_EMAIL@gmail.com
quarkus.mailer.password=SUA_SENHA_DE_APP
quarkus.mailer.from=SEU_EMAIL@gmail.com
quarkus.mailer.mock=false

# CORS 
quarkus.http.cors=true
quarkus.http.cors.origins=*
quarkus.http.cors.methods=GET,POST,PUT,DELETE,OPTIONS
quarkus.http.cors.headers=Content-Type,Authorization

# Rate limiting
quarkus.http.limits.max-connections=100

# JWT
mp.jwt.verify.publickey.location=publicKey.pem
smallrye.jwt.sign.key.location=privateKey.pem
mp.jwt.verify.issuer=https://programa-de-gestao.com
smallrye.jwt.new-token.lifespan=28800
refresh.token.lifespan=604800 

# Swagger
quarkus.http.auth.permission.swagger.paths=/swagger-ui/*,/q/swagger-ui/*,/q/openapi/*,/openapi/*,/v3/api-docs/*
quarkus.http.auth.permission.swagger.policy=permit

# Endpoints públicos
quarkus.http.auth.permission.public.paths=/auth/*
quarkus.http.auth.permission.public.policy=permit

# Endpoints protegidos
quarkus.http.auth.permission.authenticated.paths=/produtos/*,/vendas/*,/materias-primas/*,/despesas/*,/lojistas/*,/cidades/*
quarkus.http.auth.permission.authenticated.policy=authenticated

# Swagger JWT
quarkus.smallrye-openapi.security-scheme=jwt
quarkus.smallrye-openapi.security-scheme-name=Authentication
quarkus.smallrye-openapi.security-scheme-description=Cole apenas o token JWT (sem a palavra Bearer)